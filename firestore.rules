rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - nome: string (optional)
    //   - matricula: string (optional)
    //   - createdAt: string (optional)
    //
    // Collection: analyses
    // Document ID: random
    // Fields:
    //   - userId: string (required)
    //   - email_usuario: string (required)
    //   - data: string
    //   - matricula: string
    //   - nome: string
    //   - horario_inicio: string
    //   - horario_termino: string
    //   - supervisao: string
    //   - operacao: string
    //   - setor: string
    //   - fazenda: string
    //   - unidade: string
    //   - condicoes_trajeto: string
    //   - condicoes_carreadores: string
    //   - condicoes_cercas: string
    //   - conservacao_placas: string
    //   - rede_eletrica: string
    //   - area_declive: string
    //   - arvores_talhoes: string
    //   - canal_vinhaca: string
    //   - canal_escoador: string
    //   - pontes_danificadas: string
    //   - erosoes_area: string
    //   - presenca_pedras: string
    //   - culturas_vizinhas: string
    //   - sede_fazenda: string
    //   - observacao_area: string
    //   - necessidade_patrol: string
    //   - email_supervisor: string
    //   - timestamp: string (required)
    //
    // Collection: stop_work
    // Document ID: random
    // Fields:
    //   - userId: string (required)
    //   - email_usuario: string (required)
    //   - data: string
    //   - equipe: string
    //   - turno: string (A, B, C)
    //   - gestor: string
    //   - duracao: string
    //   - local_setor: string
    //   - temas: string
    //   - foto: string
    //   - timestamp: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "arcepedro600@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 100;
    }

    function isValidAnalysis(data) {
      return data.keys().hasAll(['userId', 'email_usuario', 'timestamp']) &&
             data.userId is string &&
             data.email_usuario is string &&
             data.timestamp is string;
    }

    function isValidStopWork(data) {
      return data.keys().hasAll(['userId', 'email_usuario', 'timestamp']) &&
             data.userId is string &&
             data.email_usuario is string &&
             data.timestamp is string;
    }

    // Match users collection
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isAuthenticated() && isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isOwner(uid) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    // Match analyses collection
    match /analyses/{analysisId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidAnalysis(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidAnalysis(request.resource.data) && isAdmin(); // Only admins can update reports for now
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Match stop_work collection
    match /stop_work/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidStopWork(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidStopWork(request.resource.data) && isAdmin();
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
