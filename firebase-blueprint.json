{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "nome": { "type": "string", "description": "User full name" },
        "matricula": { "type": "string", "description": "User registration number" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" }
      },
      "required": ["uid", "email", "nome", "matricula", "createdAt", "role"]
    },
    "Analysis": {
      "title": "Analysis",
      "description": "Risk analysis report",
      "type": "object",
      "properties": {
        "data": { "type": "string", "description": "Report date" },
        "matricula": { "type": "string", "description": "User registration number" },
        "nome": { "type": "string", "description": "User full name" },
        "horario_inicio": { "type": "string", "description": "Start time" },
        "horario_termino": { "type": "string", "description": "End time" },
        "supervisao": { "type": "string", "description": "Supervision area" },
        "operacao": { "type": "string", "description": "Operation type" },
        "setor": { "type": "string", "description": "Sector" },
        "fazenda": { "type": "string", "description": "Farm" },
        "unidade": { "type": "string", "description": "Unit" },
        "condicoes_trajeto": { "type": "string", "description": "Route conditions" },
        "condicoes_carreadores": { "type": "string", "description": "Internal road conditions" },
        "condicoes_cercas": { "type": "string", "description": "Fence conditions" },
        "conservacao_placas": { "type": "string", "description": "Sign conservation" },
        "rede_eletrica": { "type": "string", "description": "Electrical grid status" },
        "area_declive": { "type": "string", "description": "Slope area status" },
        "arvores_talhoes": { "type": "string", "description": "Trees in plots status" },
        "canal_vinhaca": { "type": "string", "description": "Vinasse canal status" },
        "canal_escoador": { "type": "string", "description": "Drainage canal status" },
        "pontes_danificadas": { "type": "string", "description": "Damaged bridges status" },
        "erosoes_area": { "type": "string", "description": "Erosion status" },
        "presenca_pedras": { "type": "string", "description": "Presence of stones status" },
        "culturas_vizinhas": { "type": "string", "description": "Neighboring crops status" },
        "sede_fazenda": { "type": "string", "description": "Farm headquarters status" },
        "observacao_area": { "type": "string", "description": "Area observations" },
        "necessidade_patrol": { "type": "string", "description": "Patrol machine need" },
        "foto_arquivo": { "type": "string", "description": "Photo URL" },
        "email_supervisor": { "type": "string", "format": "email", "description": "Supervisor email" },
        "email_usuario": { "type": "string", "format": "email", "description": "User email" },
        "userId": { "type": "string", "description": "User ID who created the report" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["userId", "timestamp", "email_supervisor", "email_usuario"]
    },
    "StopWork": {
      "title": "StopWork",
      "description": "Stop work registration",
      "type": "object",
      "properties": {
        "data": { "type": "string", "description": "Registration date" },
        "equipe": { "type": "string", "description": "Team name" },
        "turno": { "type": "string", "description": "Shift" },
        "gestor": { "type": "string", "description": "Manager name" },
        "duracao": { "type": "string", "description": "Duration" },
        "local_setor": { "type": "string", "description": "Location/Sector" },
        "temas": { "type": "string", "description": "Topics addressed" },
        "foto": { "type": "string", "description": "Photo URL" },
        "email_usuario": { "type": "string", "format": "email", "description": "User email" },
        "userId": { "type": "string", "description": "User ID who created the registration" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["userId", "timestamp", "email_usuario"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/analyses/{analysisId}": {
      "schema": "Analysis",
      "description": "Risk analysis reports"
    },
    "/stop_work/{stopWorkId}": {
      "schema": "StopWork",
      "description": "Stop work registrations"
    }
  }
}
