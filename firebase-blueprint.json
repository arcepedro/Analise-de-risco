{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User's Outlook email" },
        "nome": { "type": "string", "description": "Full name" },
        "matricula": { "type": "string", "description": "Employee ID" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Analysis": {
      "title": "Risk Analysis Report",
      "description": "Stores risk analysis reports submitted by users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "UID of the user who submitted" },
        "email_usuario": { "type": "string", "format": "email" },
        "data": { "type": "string" },
        "matricula": { "type": "string" },
        "nome": { "type": "string" },
        "horario_inicio": { "type": "string" },
        "horario_termino": { "type": "string" },
        "supervisao": { "type": "string" },
        "operacao": { "type": "string" },
        "setor": { "type": "string" },
        "fazenda": { "type": "string" },
        "unidade": { "type": "string" },
        "condicoes_trajeto": { "type": "string" },
        "condicoes_carreadores": { "type": "string" },
        "condicoes_cercas": { "type": "string" },
        "conservacao_placas": { "type": "string" },
        "rede_eletrica": { "type": "string" },
        "area_declive": { "type": "string" },
        "arvores_talhoes": { "type": "string" },
        "canal_vinhaca": { "type": "string" },
        "canal_escoador": { "type": "string" },
        "pontes_danificadas": { "type": "string" },
        "erosoes_area": { "type": "string" },
        "presenca_pedras": { "type": "string" },
        "culturas_vizinhas": { "type": "string" },
        "sede_fazenda": { "type": "string" },
        "observacao_area": { "type": "string" },
        "necessidade_patrol": { "type": "string" },
        "email_supervisor": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email_usuario", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/analyses/{analysisId}": {
      "schema": "Analysis",
      "description": "Analysis reports"
    }
  }
}
